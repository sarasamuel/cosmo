# Supabase — cloud backup/sync (optional; the app runs fully offline without it).
# Copy this file to `.env`, fill in your project's values, and restart Metro.
#
# Find these in: Supabase Dashboard → Project Settings → API
#   Project URL  → EXPO_PUBLIC_SUPABASE_URL
#   anon public  → EXPO_PUBLIC_SUPABASE_ANON_KEY   (safe to ship; RLS protects data)
#
# Expo only exposes vars prefixed EXPO_PUBLIC_ to the app bundle.

EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
