{
  "expo": {
    "name": "Cosmo",
    "slug": "cosmo",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "cosmo",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": true,
      "userInterfaceStyle": "automatic",
      "bundleIdentifier": "com.cosmoapp.cosmo",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.cosmoapp.cosmo",
      "userInterfaceStyle": "automatic",
      "adaptiveIcon": {
        "backgroundColor": "#0a0a15",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-font",
      "expo-notifications",
      "expo-secure-store",
      [
        "expo-calendar",
        {
          "calendarPermission": "Cosmo adds your planned sessions to your calendar so you can see them alongside the rest of your week.",
          "remindersPermission": "Cosmo can add your planned sessions as reminders."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "e05288e8-ef15-45c5-9a29-543a8361a0c4"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/e05288e8-ef15-45c5-9a29-543a8361a0c4"
    }
  }
}
